/*
 * 7x15 矩阵键盘 - nice!nano 引脚（row2col）
 * 以下与 ZMK app/module/boards/nicekeyboards/nice_nano/arduino_pro_micro_pins.dtsi 一致。
 *
 * row（输出）7 个 — 板子标号 → 芯片引脚:
 *   row0  pro_micro 0   D0   →  P0.8
 *   row1  pro_micro 1   D1   →  P0.6
 *   row2  pro_micro 2   D2   →  P0.17
 *   row3  pro_micro 3   D3   →  P0.20
 *   row4  pro_micro 4   D4   →  P0.22
 *   row5  pro_micro 5   D5   →  P0.24
 *   row6  pro_micro 6   D6   →  P1.0
 *
 * col（输入）15 个:
 *   col0   pro_micro 7   D7   →  P0.11
 *   col1   pro_micro 8   D8   →  P1.4
 *   col2   pro_micro 9   D9   →  P1.6
 *   col3   pro_micro 10  D10  →  P0.9
 *   col4   pro_micro 14  D14  →  P1.11
 *   col5   pro_micro 15  D15  →  P1.13
 *   col6   pro_micro 16  D16  →  P0.10
 *   col7   pro_micro 18  D18/A0 → P1.15
 *   col8   pro_micro 19  D19/A1 → P0.2
 *   col9   pro_micro 20  D20/A2 → P0.29  (部分板子用作 USB，慎用)
 *   col10  pro_micro 21  D21/A3 → P0.31
 *   col11  gpio0 25     →  P0.25  (需核对板子是否引出)
 *   col12  gpio0 26     →  P0.26  (需核对板子是否引出)
 *   col13  gpio0 27     →  P0.27  (需核对板子是否引出)
 *   col14  gpio1 1      →  P1.1   (需核对板子是否引出)
 *
 * 电平（实测）: 接 row 后 不按=0V、按下=110mV，两者都低无法区分。
 * 改为：扫描时 row 输出高（3.3V），col 下拉；不按=0V（低），按下=col 接到 row 高≈3.3V（高），即可区分。
 * SPDX-License-Identifier: MIT
 */

#include "matrix_7x15.dtsi"

&kscan0 {
    /* 扫描时「当前行」输出高（3.3V），按下时 col 被该行拉高 */
    row-gpios
        = <&pro_micro 0 GPIO_ACTIVE_HIGH>
        , <&pro_micro 1 GPIO_ACTIVE_HIGH>
        , <&pro_micro 2 GPIO_ACTIVE_HIGH>
        , <&pro_micro 3 GPIO_ACTIVE_HIGH>
        , <&pro_micro 4 GPIO_ACTIVE_HIGH>
        , <&pro_micro 5 GPIO_ACTIVE_HIGH>
        , <&pro_micro 6 GPIO_ACTIVE_HIGH>
        ;

    /* col 下拉；不按=0V（低），按下=读到高（3.3V） */
    col-gpios
        = <&pro_micro 7  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 8  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 16 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&gpio0 25 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&gpio0 26 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&gpio0 27 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        , <&gpio1 1  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        ;
};
